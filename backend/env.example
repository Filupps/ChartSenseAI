# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=ChartSenseAI

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API Security (опционально)
# API_KEY_REQUIRED=false  # Включить защиту API ключом (true/false)
# API_KEY=your_secret_key_here  # Секретный ключ для доступа к API

# Model Settings
MODEL_PATH=yolov8n_diagrams.pt
MODEL_FALLBACK=yolov8s.pt

# Tesseract OCR
TESSERACT_LANG=rus+eng

